# =============================================================================
# DirectLog Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# For development, most defaults work out of the box.
# For production, review ALL values carefully.
#
# SECURITY: Never commit .env files to version control!

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED — the app will not start without this.
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins.
# Development: * (allow all)
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Flask Settings
# -----------------------------------------------------------------------------
# Enable Flask debug mode (DO NOT use in production)
FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Storage backend for rate limiter counters.
# memory://       — single worker (development / single-process deployment)
# redis://host:port — shared across workers (production with gunicorn)
RATE_LIMIT_STORAGE_URI=memory://

# -----------------------------------------------------------------------------
# Database (optional — defaults to SQLite)
# -----------------------------------------------------------------------------
# Uncomment to use PostgreSQL instead of SQLite in production.
# DATABASE_URL=postgresql://user:password@localhost:5432/directlog

# -----------------------------------------------------------------------------
# Server (used by gunicorn in production)
# -----------------------------------------------------------------------------
# HOST=0.0.0.0
# PORT=5001
# WORKERS=4
